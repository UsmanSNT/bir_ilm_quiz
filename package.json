{
  "name": "bir-ilm-platform",
  "private": true,
  "version": "0.1.0",
  "description": "BIR ILM educational platform and BIR ILM QUIZ Telegram Mini App.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @bir-ilm/web",
    "dev:api": "npm run dev --workspace @bir-ilm/api",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
